{
    "name": "discord-protos",
    "version": "1.2.139",
    "description": "A parser for Discord's protobufs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "contributors": [
        {
            "name": "dolfies",
            "email": "me@dolfi.es",
            "url": "https://dolfi.es"
        },
        {
            "name": "Samuel Scheit",
            "email": "github@samuelscheit.com",
            "url": "https://samuelscheit.com"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/discord-userdoccers/discord-protos.git"
    },
    "homepage": "https://github.com/discord-userdoccers/discord-protos#readme",
    "bugs": {
        "url": "https://github.com/discord-userdoccers/discord-protos/issues"
    },
    "license": "MIT",
    "type": "commonjs",
    "scripts": {
        "load": "node --experimental-strip-types scripts/load.mts",
        "build": "tsc"
