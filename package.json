        "README.md",
        "LICENSE",
        "package.json"
    ],
    "devDependencies": {
        "@protobuf-ts/plugin": "^2.11.1",
        "@protobuf-ts/protoc": "^2.11.1",
        "puppeteer": "^24.38.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@protobuf-ts/runtime": "^2.11.1"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "packageManager": "pnpm@10.24.0"
